{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "gen:api": {
      "inputs": ["apps/api/prisma/schema.prisma"],
      "cache": true
    },
    "build": {
      "dependsOn": ["^build", "gen:api"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**"] 
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types", "gen:api"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}