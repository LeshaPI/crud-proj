{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "gen:db": {
      "inputs": ["packages/db/prisma/schema.prisma"],
      "cache": true
    },
    "build": {
      "dependsOn": ["^build", "gen:db"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [
        "dist/**", 
        ".next/**", 
        "apps/mobile/dist/**"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["gen:db"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}